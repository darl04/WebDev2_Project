{% extends 'base.html.twig' %}

{% block title %}DRAMATIQUE{% endblock %}

{% block body %}
    <h1>Products</h1>

    <div class="table-container">
    <table class="table">
        <tbody>
            <tr>
                <th>Image</th>
                <td>
                    {% if product.image %}
                        <img src="{{ product.image }}" alt="{{ product.name }}" style="max-width: 300px; max-height: 300px; border-radius: 8px; border: 2px solid #e0e0e0; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);">
                    {% else %}
                        <span style="color: #999; font-style: italic;">No image available</span>
                    {% endif %}
                </td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ product.name }}</td>
            </tr>
            <tr>
                <th>Price</th>
                <td>{{ product.price }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ product.description }}</td>
            </tr>
            <tr>
                <th>Collection</th>
                <td>{{ product.collectionType ?: 'Uncategorized' }}</td>
            </tr>
        </tbody>
    </table>
    </div>

    <a href="{{ path('app_products_index') }}" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back to list</a>

    {% set isOwner = product.getCreatedBy() and app.user and product.getCreatedBy().getId() == app.user.getId() %}
    {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') or isOwner %}
        <a href="{{ path('app_products_edit', {'id': product.id}) }}" class="btn btn-secondary"><i class="fas fa-edit"></i> Edit</a>

        {{ include('products/_delete_form.html.twig') }}
    {% endif %}
{% endblock %}
